{
  "name": "@geond-agent/desktop",
  "version": "0.0.0",
  "private": true,
  "description": "Native desktop app for geond-agent.",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json --noEmit && vite build && pnpm build:budget",
    "build:budget": "node scripts/check-chunk-budget.mjs",
    "dev": "vite",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --config vitest.config.ts && tsc -p tsconfig.json --noEmit",
    "test:e2e": "playwright test",
    "test:e2e:layout": "playwright test e2e/layout.spec.ts --grep @layout",
    "test:e2e:visual": "pnpm test:e2e:layout",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build --bundles app"
  },
  "dependencies": {
    "@geond-agent/claude-code-bridge": "workspace:*",
    "@geond-agent/ui-workbench": "workspace:*",
    "@geond-agent/zai-provider": "workspace:*",
    "@radix-ui/react-tabs": "^1.1.13",
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-dialog": "^2.0.0",
    "clsx": "^2.1.1",
    "lucide-react": "^1.21.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwind-merge": "^3.3.1"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "vite": "^7.1.10"
  }
}
