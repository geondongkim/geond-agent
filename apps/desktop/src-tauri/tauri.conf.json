{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "geond-agent",
  "version": "0.0.0",
  "identifier": "kim.geond.geond-agent",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "geond-agent",
        "width": 1540,
        "height": 980,
        "minWidth": 1180,
        "minHeight": 760,
        "resizable": true
      }
    ]
  }
}
