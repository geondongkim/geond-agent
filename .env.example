# Copy to .env.local or your shell profile. Do not commit real secrets.

# Z.ai GLM Coding Plan key. Prefer local shell/keychain storage.
ZAI_API_KEY=

# Anthropic-compatible endpoint used by Z.ai GLM Coding Plan.
ANTHROPIC_BASE_URL=https://api.z.ai/api/anthropic

# Cost-effective default routing.
ANTHROPIC_DEFAULT_HAIKU_MODEL=glm-4.7
ANTHROPIC_DEFAULT_SONNET_MODEL=glm-4.7
ANTHROPIC_DEFAULT_OPUS_MODEL=glm-5.2

# Goose bridge defaults.
GOOSE_PROVIDER=claude-acp
GOOSE_MODEL=sonnet
