{
  "name": "geond-agent",
  "version": "0.0.0",
  "private": true,
  "description": "Local agent workbench for coding agents, sessions, diffs, and tool orchestration.",
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm --filter @geond-agent/desktop dev",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "test:e2e": "pnpm --filter @geond-agent/desktop test:e2e",
    "verify": "git diff --check && pnpm lint && pnpm test && pnpm build"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@types/node": "^24.10.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
